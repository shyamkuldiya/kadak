{
  "name": "@shyk/kadak",
  "version": "0.0.1",
  "description": "PostgreSQL Data Runtime",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "kadak": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/exec/client.d.ts",
      "import": "./dist/exec/client.js",
      "require": "./dist/exec/client.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "keywords": [
    "postgres",
    "runtime",
    "orm",
    "database"
  ],
  "author": "Shyam Kuldiya",
  "license": "Apache-2.0",
  "type": "module",
  "dependencies": {
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
